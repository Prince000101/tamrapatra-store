{
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://tamrapatra-store.onrender.com/api/:path*" },
    { "source": "/uploads/:path*", "destination": "https://tamrapatra-store.onrender.com/uploads/:path*" },
    { "source": "/((?!assets/|favicon\\.svg|icons\\.svg|robots\\.txt|sitemap\\.xml).*)", "destination": "/index.html" }
  ]
}
